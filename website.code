<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EruvGuard — We Watch the Eruv So You Don't Have To</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-primary: #1565C0;
    --blue-mid:     #1976D2;
    --blue-light:   #42A5F5;
    --blue-pale:    #BBDEFB;
    --blue-bg:      #E3F2FD;
    --white:        #FFFFFF;
    --off-white:    #F4F9FF;
    --text-dark:    #0D2B5E;
    --text-mid:     #2C5282;
    --text-muted:   #607D9E;
    --nav-height:   64px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Open Sans', sans-serif;
    background: var(--white);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    height: var(--nav-height);
    background: var(--white);
    border-bottom: 3px solid var(--blue-primary);
    z-index: 1000;
    display: flex; align-items: center;
    padding: 0 28px;
    gap: 12px;
    box-shadow: 0 2px 16px rgba(21,101,192,0.12);
  }
  .nav-logo {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--blue-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-logo span { color: var(--blue-light); }
  .nav-divider {
    width: 1px; height: 30px;
    background: var(--blue-pale);
    flex-shrink: 0;
  }
  .nav-links {
    display: flex; gap: 5px;
    list-style: none;
    overflow-x: auto;
    scrollbar-width: none;
    flex-wrap: nowrap;
  }
  .nav-links::-webkit-scrollbar { display: none; }
  .nav-links a {
    display: inline-block;
    padding: 6px 13px;
    border-radius: 20px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--blue-primary);
    border: 1.5px solid var(--blue-pale);
    background: var(--white);
    white-space: nowrap;
    transition: all 0.18s;
  }
  .nav-links a:hover,
  .nav-links a.active {
    background: var(--blue-primary);
    color: var(--white);
    border-color: var(--blue-primary);
  }

  /* SECTIONS */
  section { padding: 90px 72px 80px; scroll-margin-top: var(--nav-height); }

  .section-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--blue-light); margin-bottom: 10px;
  }
  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900; color: var(--blue-primary);
    line-height: 1.1; margin-bottom: 14px;
  }
  .section-subtitle {
    font-size: 1rem; color: var(--text-mid);
    line-height: 1.8; max-width: 640px; margin-bottom: 44px;
  }
  .blue-bar {
    width: 52px; height: 5px;
    background: linear-gradient(90deg, var(--blue-primary), var(--blue-light));
    border-radius: 4px; margin: 10px 0 28px;
  }

  /* HERO */
  #hero {
    min-height: 100vh;
    background: linear-gradient(155deg, var(--blue-primary) 0%, var(--blue-mid) 55%, #2196F3 100%);
    display: flex; align-items: center;
    padding: 120px 72px 80px;
    position: relative; overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23FFFFFF' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.09); pointer-events: none;
  }
  .hero-ring-1 { width: 700px; height: 700px; right: -200px; top: -200px; }
  .hero-ring-2 { width: 480px; height: 480px; right: 0; top: -80px; border-color: rgba(255,255,255,0.06); }
  .hero-ring-3 { width: 260px; height: 260px; left: 38%; bottom: 8%; border-color: rgba(255,255,255,0.05); }

  .hero-content { position: relative; z-index: 2; max-width: 680px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.28);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    padding: 8px 20px; border-radius: 40px; margin-bottom: 30px;
  }
  .hero-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900; color: var(--white);
    line-height: 1.05; margin-bottom: 8px; letter-spacing: -0.02em;
  }
  .hero-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.1rem, 2.2vw, 1.7rem);
    font-weight: 700; font-style: italic;
    color: rgba(255,255,255,0.72); margin-bottom: 26px;
  }
  .hero-tagline {
    font-size: 1rem; font-weight: 300;
    color: rgba(255,255,255,0.78); line-height: 1.78;
    max-width: 540px; margin-bottom: 44px;
  }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-white {
    background: var(--white); color: var(--blue-primary);
    padding: 14px 34px; border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.82rem;
    letter-spacing: 0.06em; text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(0,0,0,0.14);
    transition: transform 0.18s, box-shadow 0.18s;
    display: inline-block;
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 26px rgba(0,0,0,0.2); }
  .btn-outline {
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.4);
    padding: 12px 32px; border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600; font-size: 0.82rem;
    letter-spacing: 0.04em; text-decoration: none;
    transition: all 0.18s; display: inline-block;
  }
  .btn-outline:hover { border-color: white; background: rgba(255,255,255,0.1); }

  /* ABSTRACT */
  #abstract { background: var(--off-white); }
  .abstract-wrap { max-width: 880px; margin: 0 auto; }
  .abstract-card {
    background: var(--white); border-radius: 8px;
    border: 1px solid var(--blue-pale);
    padding: 52px 60px;
    box-shadow: 0 8px 36px rgba(21,101,192,0.08);
    position: relative; overflow: hidden;
  }
  .abstract-card::before {
    content: '❝';
    position: absolute; top: 14px; left: 26px;
    font-size: 6.5rem; color: var(--blue-bg);
    font-family: Georgia, serif; line-height: 1; pointer-events: none;
  }
  .abstract-card p {
    font-size: 1rem; line-height: 1.95;
    color: var(--text-mid); position: relative; z-index: 1;
  }
  .abstract-note {
    text-align: center; margin-top: 18px;
    font-size: 0.78rem; color: var(--text-muted); letter-spacing: 0.05em;
  }

  /* PROBLEM */
  #problem { background: var(--white); }
  .problem-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
  }
  .problem-card {
    background: var(--blue-bg); border-radius: 8px;
    padding: 30px 28px; border-left: 5px solid var(--blue-primary);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .problem-card:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(21,101,192,0.11); }
  .p-icon { font-size: 1.9rem; margin-bottom: 12px; }
  .problem-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.97rem; font-weight: 700;
    color: var(--blue-primary); margin-bottom: 9px;
  }
  .problem-card p { font-size: 0.92rem; color: var(--text-mid); line-height: 1.72; }

  /* SOLUTION */
  #solution { background: linear-gradient(135deg, var(--blue-primary) 0%, var(--blue-mid) 100%); }
  #solution .section-eyebrow { color: var(--blue-pale); }
  #solution .section-title { color: var(--white); }
  #solution .section-subtitle { color: rgba(255,255,255,0.68); }
  #solution .blue-bar { background: linear-gradient(90deg, #fff, var(--blue-pale)); }
  .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
  .feature-card {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.17);
    border-radius: 8px; padding: 28px 22px;
    transition: background 0.2s, border-color 0.2s;
  }
  .feature-card:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.38); }
  .f-icon {
    width: 44px; height: 44px; background: rgba(255,255,255,0.14);
    border-radius: 50%; display: flex; align-items: center;
    justify-content: center; font-size: 1.25rem; margin-bottom: 14px;
  }
  .feature-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.92rem; font-weight: 700; color: var(--white); margin-bottom: 8px;
  }
  .feature-card p { font-size: 0.86rem; color: rgba(255,255,255,0.62); line-height: 1.7; }

  /* HOW IT WORKS */
  #how-it-works { background: var(--off-white); }
  .steps-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 18px; }
  .step-card {
    background: var(--white); border-radius: 8px;
    border: 1px solid var(--blue-pale);
    padding: 30px 26px; display: flex; gap: 18px;
    transition: box-shadow 0.2s;
  }
  .step-card:hover { box-shadow: 0 10px 30px rgba(21,101,192,0.1); }
  .step-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.8rem; font-weight: 900;
    color: var(--blue-pale); line-height: 1; min-width: 44px;
  }
  .step-tag {
    display: inline-block; background: var(--blue-bg);
    color: var(--blue-primary);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 9px; border-radius: 20px; margin-bottom: 9px;
  }
  .step-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.97rem; font-weight: 700;
    color: var(--blue-primary); margin-bottom: 7px;
  }
  .step-card p { font-size: 0.89rem; color: var(--text-mid); line-height: 1.75; }

  /* IMPACT */
  #impact { background: var(--white); }
  .stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
  .stat-block {
    background: linear-gradient(135deg, var(--blue-primary), var(--blue-mid));
    border-radius: 8px; padding: 46px 28px;
    text-align: center; position: relative; overflow: hidden;
  }
  .stat-block::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 4px; background: var(--blue-light);
  }
  .stat-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 3.4rem; font-weight: 900;
    color: var(--white); line-height: 1; margin-bottom: 10px;
  }
  .stat-lbl {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--blue-pale); margin-bottom: 10px;
  }
  .stat-note { font-size: 0.8rem; color: rgba(255,255,255,0.48); line-height: 1.5; }
  .impact-note {
    text-align: center; margin-top: 18px;
    font-size: 0.8rem; color: var(--text-muted); font-style: italic;
  }

  /* RESEARCH */
  #research { background: var(--blue-bg); }
  .research-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: start; }
  .research-text p { font-size: 0.95rem; color: var(--text-mid); line-height: 1.87; margin-bottom: 16px; }
  .research-text strong { color: var(--blue-primary); }
  .source-credit {
    margin-top: 18px; padding: 14px 18px;
    background: var(--white); border-left: 4px solid var(--blue-primary);
    border-radius: 0 6px 6px 0; font-size: 0.84rem; color: var(--text-mid);
  }
  .source-credit strong {
    display: block; font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue-light); margin-bottom: 4px;
  }
  .compare-card {
    background: var(--blue-primary); border-radius: 8px;
    padding: 34px 30px; color: var(--white);
  }
  .compare-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.97rem; font-weight: 700; color: var(--white);
    margin-bottom: 20px; padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.14);
  }
  .cmp-row {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 10px;
    padding: 11px 0; border-bottom: 1px solid rgba(255,255,255,0.08);
    font-size: 0.84rem;
  }
  .cmp-row:last-child { border-bottom: none; }
  .cmp-lbl { color: rgba(255,255,255,0.48); flex-shrink: 0; min-width: 90px; }
  .cmp-them { color: #ff8a80; font-weight: 700; text-align: right; }
  .cmp-us   { color: #69f0ae; font-weight: 700; text-align: right; }

  /* TEAM */
  #team { background: var(--white); }
  .team-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
  .team-card {
    background: var(--white); border-radius: 8px;
    border: 1px solid var(--blue-pale); overflow: hidden;
    box-shadow: 0 4px 18px rgba(21,101,192,0.07);
    transition: transform 0.22s, box-shadow 0.22s;
  }
  .team-card:hover { transform: translateY(-4px); box-shadow: 0 16px 38px rgba(21,101,192,0.13); }
  .team-photo {
    width: 100%; height: 200px;
    background: linear-gradient(135deg, var(--blue-bg), var(--blue-pale));
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    border-bottom: 4px solid var(--blue-primary);
    color: var(--text-muted);
  }
  .team-photo svg { margin-bottom: 10px; opacity: 0.38; }
  .team-photo span { font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--blue-light); }
  .team-info { padding: 22px 24px 26px; }
  .team-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.08rem; font-weight: 700; color: var(--blue-primary); margin-bottom: 3px;
  }
  .team-role {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.67rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue-light); margin-bottom: 14px;
  }
  .team-resp { list-style: none; }
  .team-resp li {
    font-size: 0.86rem; color: var(--text-mid);
    padding: 4px 0 4px 15px; position: relative; line-height: 1.52;
  }
  .team-resp li::before { content: '–'; position: absolute; left: 0; color: var(--blue-light); }

  /* PROGRESS */
  #progress { background: linear-gradient(155deg, var(--blue-primary) 0%, #1565C0 100%); }
  #progress .section-eyebrow { color: var(--blue-pale); }
  #progress .section-title { color: var(--white); }
  #progress .section-subtitle { color: rgba(255,255,255,0.62); }
  #progress .blue-bar { background: linear-gradient(90deg, #fff, var(--blue-pale)); }
  .progress-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
  .progress-slot {
    background: rgba(255,255,255,0.07);
    border: 2px dashed rgba(255,255,255,0.24);
    border-radius: 8px; min-height: 195px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 26px 18px; text-align: center;
    transition: background 0.2s, border-color 0.2s; cursor: pointer;
  }
  .progress-slot:hover { background: rgba(255,255,255,0.13); border-color: rgba(255,255,255,0.48); }
  .progress-slot svg { opacity: 0.28; margin-bottom: 12px; }
  .slot-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem; font-weight: 700;
    color: rgba(255,255,255,0.68); margin-bottom: 6px;
  }
  .slot-desc { font-size: 0.74rem; color: rgba(255,255,255,0.32); }
  .progress-note { text-align: center; margin-top: 18px; font-size: 0.78rem; color: rgba(255,255,255,0.28); font-style: italic; }

  /* AUDIENCE */
  #audience { background: var(--off-white); }
  .audience-split { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .audience-list { list-style: none; }
  .audience-list li {
    display: flex; align-items: flex-start; gap: 15px;
    padding: 19px 0; border-bottom: 1px solid var(--blue-pale);
  }
  .audience-list li:last-child { border-bottom: none; }
  .aud-icon {
    width: 40px; height: 40px;
    background: var(--blue-primary); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .aud-text strong {
    display: block; font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem; font-weight: 700; color: var(--blue-primary); margin-bottom: 3px;
  }
  .aud-text span { font-size: 0.86rem; color: var(--text-mid); line-height: 1.65; }
  .limits-box {
    background: var(--white); border-radius: 8px;
    border-top: 5px solid var(--blue-primary);
    padding: 34px 30px;
    box-shadow: 0 4px 18px rgba(21,101,192,0.07);
  }
  .limits-box h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem; font-weight: 700; color: var(--blue-primary); margin-bottom: 18px;
  }
  .lim-item { display: flex; gap: 11px; margin-bottom: 14px; align-items: flex-start; }
  .lim-dot { width: 7px; height: 7px; background: var(--blue-light); border-radius: 50%; margin-top: 6px; flex-shrink: 0; }
  .lim-item p { font-size: 0.89rem; color: var(--text-mid); line-height: 1.65; }

  /* FUTURE */
  #future { background: var(--white); }
  .future-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; }
  .future-item {
    background: var(--blue-bg); border-radius: 8px;
    padding: 22px 24px; display: flex; gap: 14px; align-items: flex-start;
    border-bottom: 3px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }
  .future-item:hover { border-color: var(--blue-primary); background: var(--blue-pale); }
  .f-arrow { font-family: 'Montserrat', sans-serif; font-weight: 700; color: var(--blue-primary); font-size: 1rem; margin-top: 2px; }
  .future-item h5 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem; font-weight: 700; color: var(--blue-primary); margin-bottom: 4px;
  }
  .future-item p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.65; }

  /* SOURCES */
  #sources { background: var(--blue-bg); padding: 70px 72px; }
  .source-item {
    padding: 16px 0; border-bottom: 1px solid var(--blue-pale);
    font-size: 0.9rem; color: var(--text-mid); line-height: 1.72;
  }
  .source-item:last-child { border-bottom: none; }
  .source-item strong {
    display: block; font-family: 'Montserrat', sans-serif;
    font-weight: 700; color: var(--blue-primary); margin-bottom: 4px;
  }

  /* FOOTER */
  footer {
    background: var(--blue-primary);
    color: rgba(255,255,255,0.48);
    text-align: center; padding: 38px 72px; font-size: 0.82rem;
  }
  .footer-logo {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem; font-weight: 900;
    color: var(--white); margin-bottom: 8px;
  }
  .footer-logo span { color: var(--blue-pale); }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    section { padding: 66px 20px; }
    nav { padding: 0 14px; gap: 8px; }
    #hero { padding: 95px 20px 56px; }
    .problem-grid,.features-grid,.steps-grid,.research-layout,
    .team-grid,.progress-grid,.audience-split,.future-grid,.stats-row {
      grid-template-columns: 1fr;
    }
    .abstract-card { padding: 36px 28px; }
    #sources, footer { padding: 40px 20px; }
  }
</style>
</head>
<body>

<!-- STICKY NAV -->
<nav>
  <div class="nav-logo">Eruv<span>Guard</span></div>
  <div class="nav-divider"></div>
  <ul class="nav-links">
    <li><a href="#abstract">About</a></li>
    <li><a href="#problem">Problem</a></li>
    <li><a href="#solution">Solution</a></li>
    <li><a href="#how-it-works">How It Works</a></li>
    <li><a href="#impact">Impact</a></li>
    <li><a href="#research">Research</a></li>
    <li><a href="#team">Team</a></li>
    
    <li><a href="#audience">Who It's For</a></li>
    <li><a href="#future">Future Plans</a></li>
